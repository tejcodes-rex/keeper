# ----------------------------------------------------------------------
# Keeper Mission Control (web) environment
# Copy this file to .env and adjust. Vite only exposes VITE_* vars.
# ----------------------------------------------------------------------

# Base URL of the Keeper backend (FastAPI). No trailing slash needed.
# The UI calls {VITE_KEEPER_URL}/api/run, /api/stream, and /api/approve.
VITE_KEEPER_URL=http://localhost:8000

# Mock mode. Set to "1" to replay a scripted World Cup incident with no
# backend at all (useful for the demo video). You can also append ?mock=1
# to the page URL at runtime. Leave empty or "0" to use the live backend.
VITE_MOCK=0
