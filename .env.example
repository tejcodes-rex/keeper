# ----------------------------------------------------------------------
# Keeper environment contract
# Copy this file to .env and fill in the values. Never commit .env.
# ----------------------------------------------------------------------

# --- Google Cloud / Vertex AI (Gemini 3.1 Pro) ---
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=TRUE
KEEPER_MODEL=gemini-3.1-pro-preview

# --- Dynatrace platform (read + act, used by the Keeper agent via MCP) ---
# Platform URL of your Dynatrace SaaS environment.
DT_ENVIRONMENT=https://abc12345.apps.dynatrace.com
# Platform token for headless MCP auth. Scopes listed in docs/RUNBOOK.md.
DT_PLATFORM_TOKEN=dt0s16.XXXXXXXX.XXXXXXXX
# Cap Grail scan cost per session.
DT_GRAIL_QUERY_BUDGET_GB=10

# --- Dynatrace ingest (used by the demo World Cup app to emit telemetry) ---
# Classic live URL for log and event ingest from the victim service.
DT_INGEST_BASE=https://abc12345.live.dynatrace.com
# API token with logs.ingest + events.ingest + metrics.ingest scopes.
DT_API_TOKEN=dt0c01.XXXXXXXX.XXXXXXXX

# --- Wiring between Keeper and the demo app ---
# Public URL of the deployed World Cup fan gateway (the service Keeper protects).
VICTIM_BASE_URL=https://worldcup-fan-gateway-xxxxxxxx-uc.a.run.app

# --- Optional notifications (Keeper Operator step) ---
# Slack connection id configured inside Dynatrace, if you want live alerts.
DT_SLACK_CONNECTION_ID=
NOTIFY_EMAIL=
